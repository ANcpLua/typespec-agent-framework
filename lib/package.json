{
  "name": "@ancplua/typespec-maf",
  "version": "0.0.0",
  "description": "TypeSpec emitters for Microsoft Agent Framework's declarative agent and workflow YAML.",
  "type": "module",
  "main": "dist/index.js",
  "tspMain": "lib/main.tsp",
  "exports": {
    ".": {
      "typespec": "./lib/main.tsp",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "prepare": "tsc -p .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@typespec/compiler": "^1.13.0"
  },
  "dependencies": {
    "yaml": "2.8.3"
  },
  "devDependencies": {
    "@types/node": "25.9.5",
    "@typespec/compiler": "1.13.0",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
