# @ancplua/* npm packages publish to / install from GitHub Packages
# (npm.pkg.github.com), not npmjs. This scope->registry map lets npm install AND
# Renovate resolve @ancplua/* registry deps (e.g. @ancplua/typespec-otel-semconv).
# CI auth: setup-node NODE_AUTH_TOKEN=GITHUB_TOKEN; local dev: a
# GitHub PAT (read:packages) in ~/.npmrc. Local file: deps (./lib) bypass this and
# resolve by path.
@ancplua:registry=https://npm.pkg.github.com
